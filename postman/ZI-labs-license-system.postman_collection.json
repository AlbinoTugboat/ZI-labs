    {
      "name": "4. Malware Signatures",
      "item": [
        {
          "name": "Create Signature (ADMIN, 201, save signatureId)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"threatName\": \"Trojan.Postman.Test\",\n  \"firstBytesHex\": \"0A0B0C0D\",\n  \"remainderHashHex\": \"AA11BB22CC33DD44\",\n  \"remainderLength\": 2048,\n  \"fileType\": \"exe\",\n  \"offsetStart\": 0,\n  \"offsetEnd\": 512\n}"
            },
            "url": "{{baseUrl}}/api/admin/signatures"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Signature status is ACTUAL', function () {",
                  "    pm.expect(json.status).to.eql('ACTUAL');",
                  "});",
                  "pm.collectionVariables.set('signatureId', json.id);",
                  "pm.collectionVariables.set('signatureSince', json.updatedAt);",
                  "pm.collectionVariables.set('signatureDigitalSignature', json.digitalSignatureBase64);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Signature from File (ADMIN, 201, save signatureId)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "{{signatureSourceFilePath}}" },
                { "key": "threatName", "type": "text", "value": "Trojan.Postman.File" }
              ]
            },
            "url": "{{baseUrl}}/api/admin/signatures/from-file"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Signature status is ACTUAL', function () {",
                  "    pm.expect(json.status).to.eql('ACTUAL');",
                  "});",
                  "pm.collectionVariables.set('signatureId', json.id);",
                  "pm.collectionVariables.set('signatureSince', json.updatedAt);",
                  "pm.collectionVariables.set('signatureDigitalSignature', json.digitalSignatureBase64);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Signature Source File Pre-Signed URLs (ADMIN, 200)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\n    \"{{signatureId}}\"\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/admin/signatures/files/pre-signed-urls"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
