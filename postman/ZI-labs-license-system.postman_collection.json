        {
          "name": "Update Signature (ADMIN, 200, signature recalculated)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"threatName\": \"Trojan.Postman.Test.V2\",\n  \"firstBytesHex\": \"0A0B0C0D\",\n  \"remainderHashHex\": \"AA11BB22CC33EE55\",\n  \"remainderLength\": 4096,\n  \"fileType\": \"dll\",\n  \"offsetStart\": 10,\n  \"offsetEnd\": 1024\n}"
            },
            "url": "{{baseUrl}}/api/admin/signatures/{{signatureId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "var previousSignature = pm.collectionVariables.get('signatureDigitalSignature');",
                  "if (previousSignature) {",
                  "    pm.test('Digital signature was recalculated', function () {",
                  "        pm.expect(json.digitalSignatureBase64).to.not.eql(previousSignature);",
                  "    });",
                  "}",
                  "pm.collectionVariables.set('signatureSince', json.updatedAt);",
                  "pm.collectionVariables.set('signatureDigitalSignature', json.digitalSignatureBase64);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
