{
  "info": {
    "name": "ZI Labs - License System API",
    "description": "Коллекция для полного тестирования текущего API проекта (auth, RBAC, license create/activate/check, негативные сценарии).\n\nВажно: сервер настроен на HTTPS (`https://localhost:8444`) с self-signed сертификатом. В Postman отключи SSL certificate verification, если запросы не проходят.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "c2f810c8-eac5-4d3f-bc3b-8b70d8d91c68"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:8444" },

    { "key": "adminUsername", "value": "admin" },
    { "key": "adminPassword", "value": "password" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "adminRefreshToken", "value": "" },

    { "key": "userUsername", "value": "user1" },
    { "key": "userPassword", "value": "password" },
    { "key": "userAccessToken", "value": "" },
    { "key": "userRefreshToken", "value": "" },

    { "key": "productId", "value": "1" },
    { "key": "licenseTypeId", "value": "1" },
    { "key": "ownerId", "value": "2" },
    { "key": "deviceCount", "value": "2" },

    { "key": "deviceMac1", "value": "AA:BB:CC:DD:EE:01" },
    { "key": "deviceName1", "value": "Laptop-User1" },
    { "key": "deviceMac2", "value": "AA:BB:CC:DD:EE:02" },
    { "key": "deviceName2", "value": "Desktop-User1" },

    { "key": "licenseId", "value": "" },
    { "key": "licenseCode", "value": "" },
    { "key": "ticketSignature", "value": "" },
    { "key": "ticketExpiration", "value": "" },

    { "key": "singleDeviceLicenseCode", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth + RBAC",
      "item": [
        {
          "name": "Public Ping (200)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/public/ping"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Admin (save tokens)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('adminAccessToken', json.accessToken);",
                  "pm.collectionVariables.set('adminRefreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login User (save tokens)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('userAccessToken', json.accessToken);",
                  "pm.collectionVariables.set('userRefreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh User Token (save new tokens)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{userRefreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('userAccessToken', json.accessToken);",
                  "pm.collectionVariables.set('userRefreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "User Me with USER token (200)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/user/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin Ping with ADMIN token (200)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/ping"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin Ping with USER token (403)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/ping"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. License Positive Flow",
      "item": [
        {
          "name": "Create License (ADMIN, 201, save code)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"typeId\": {{licenseTypeId}},\n  \"ownerId\": {{ownerId}},\n  \"deviceCount\": {{deviceCount}},\n  \"description\": \"Postman positive flow license\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/licenses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('licenseId', String(json.id));",
                  "pm.collectionVariables.set('licenseCode', json.code);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Activate License on Device #1 (USER, 200)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"{{licenseCode}}\",\n  \"deviceMac\": \"{{deviceMac1}}\",\n  \"deviceName\": \"{{deviceName1}}\"\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/activate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('ticketSignature', json.signature);",
                  "pm.collectionVariables.set('ticketExpiration', json.expiration);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Check License for Device #1 (USER, 200)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceMac\": \"{{deviceMac1}}\",\n  \"productId\": {{productId}}\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/check"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Activate License on Device #2 (USER, 200 if deviceCount >= 2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"{{licenseCode}}\",\n  \"deviceMac\": \"{{deviceMac2}}\",\n  \"deviceName\": \"{{deviceName2}}\"\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/activate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Check License for Device #2 (USER, 200)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceMac\": \"{{deviceMac2}}\",\n  \"productId\": {{productId}}\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/check"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. License Negative Flow",
      "item": [
        {
          "name": "Create License with USER token (403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"typeId\": {{licenseTypeId}},\n  \"ownerId\": {{ownerId}},\n  \"deviceCount\": 1,\n  \"description\": \"Should fail for USER role\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/licenses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Check License from another user context (ADMIN token, 404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceMac\": \"{{deviceMac1}}\",\n  \"productId\": {{productId}}\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/check"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Activate with invalid key (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"LIC-INVALID-KEY-000000\",\n  \"deviceMac\": \"AA:BB:CC:DD:EE:99\",\n  \"deviceName\": \"UnknownDevice\"\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/activate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create single-device license (ADMIN, save code)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"typeId\": {{licenseTypeId}},\n  \"ownerId\": {{ownerId}},\n  \"deviceCount\": 1,\n  \"description\": \"Limit test license\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/licenses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('singleDeviceLicenseCode', json.code);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Activate single-device license on Device #1 (200)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"{{singleDeviceLicenseCode}}\",\n  \"deviceMac\": \"AA:BB:CC:DD:EE:11\",\n  \"deviceName\": \"LimitDevice1\"\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/activate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Activate single-device license on Device #2 (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"{{singleDeviceLicenseCode}}\",\n  \"deviceMac\": \"AA:BB:CC:DD:EE:12\",\n  \"deviceName\": \"LimitDevice2\"\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/activate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 409', function () {",
                  "    pm.response.to.have.status(409);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Check license with unknown device (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceMac\": \"AA:BB:CC:DD:EE:FE\",\n  \"productId\": {{productId}}\n}"
            },
            "url": "{{baseUrl}}/api/user/licenses/check"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
