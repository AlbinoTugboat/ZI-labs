DB_URL=jdbc:postgresql://localhost:5433/information_protection_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

JWT_SECRET=change-this-jwt-secret-min-32-characters
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=86400000

SSL_KEYSTORE_PASSWORD=change-me
SIGNATURE_KEY_STORE_PATH=classpath:ssl/server.p12
SIGNATURE_KEY_STORE_TYPE=PKCS12
SIGNATURE_KEY_STORE_PASSWORD=change-me
SIGNATURE_KEY_ALIAS=
SIGNATURE_KEY_PASSWORD=change-me
SIGNATURE_ALGORITHM=SHA256withRSA
SIGNATURE_FAIL_FAST=true

POSTGRES_DB=information_protection_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST_PORT=5433

MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=change-me-minio-root
MINIO_ACCESS_KEY=app-signature-user
MINIO_SECRET_KEY=change-me-minio-app
MINIO_BUCKET=signature-files
MINIO_ENDPOINT=http://localhost:9000
MINIO_PRESIGNED_TTL_SECONDS=900
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
